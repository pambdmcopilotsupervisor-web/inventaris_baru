model overtime_requests {
  id                     BigInt             @id @default(autoincrement()) @db.UnsignedBigInt
  karyawan_id            BigInt             @db.UnsignedBigInt
  tanggal_lembur         DateTime           @db.Date
  jam_mulai_rencana      String             @db.VarChar(8)
  jam_selesai_rencana    String             @db.VarChar(8)
  durasi_rencana_menit   Int                @default(0)
  jam_mulai_aktual       String?            @db.VarChar(8)
  jam_selesai_aktual     String?            @db.VarChar(8)
  durasi_aktual_menit    Int?
  durasi_disetujui_menit Int?
  alasan_lembur          String             @db.Text
  pekerjaan_lembur       String?            @db.Text
  lampiran               String?            @db.VarChar(255)
  status                 String             @default("draft") @db.VarChar(30)
  total_uang_lembur      Decimal?           @db.Decimal(15, 2)
  calculation_detail     Json?
  catatan_realisasi      String?            @db.Text
  is_lintas_hari         Boolean            @default(false)
  overtime_setting_id    BigInt?            @db.UnsignedBigInt
  submitted_at           DateTime?          @db.Timestamp(0)
  realized_at            DateTime?          @db.Timestamp(0)
  dibuat_oleh            BigInt?            @db.UnsignedBigInt
  created_at             DateTime?          @db.Timestamp(0)
  updated_at             DateTime?          @db.Timestamp(0)
