model overtime_settings {
  id                         BigInt              @id @default(autoincrement()) @db.UnsignedBigInt
  nama_setting               String              @db.VarChar(100)
  tipe_hari                  String              @default("hari_kerja") @db.VarChar(20)
  metode_perhitungan         String              @default("per_jam") @db.VarChar(20)
  tarif_flat                 Decimal             @default(0) @db.Decimal(15, 2)
  tarif_per_jam              Decimal             @default(0) @db.Decimal(15, 2)
