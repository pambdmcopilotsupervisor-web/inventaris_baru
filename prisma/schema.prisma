// ─── Payroll (Penggajian) ────────────────────────────────────────
// Prinsip: komponen dinamis/configurable, setiap payroll = snapshot immutable
// (kode/nama/nilai komponen dibekukan di payroll_slip_details), nilai mengacu
// pada data periode berjalan.

// ─── Enums Payroll ───────────────────────────────────────────────
enum PayrollComponentType {
  EARNING
  DEDUCTION
}

enum PayrollCalcMethod {
  FIXED
  PERCENT
  FORMULA
}

enum AttendanceTriggerType {
  ALFA
  LATE
  EARLY_LEAVE
  SICK_NO_CERT
}

enum AttendanceDeductionMethod {
  PER_DAY
  PER_HOUR
  PER_MINUTE
  FLAT
  PERCENT
}

enum LateTierDeductionType {
  FIXED
  PERCENT
  PER_HOUR
}

enum PayrollPeriodStatus {
  DRAFT
  CALCULATED
  APPROVED
  PAID
  CLOSED
}

enum PayrollSlipStatus {
  PENDING
  REVIEWED
  APPROVED
}

enum PayrollRunType {
  REGULER
  THR
  BONUS
}

enum PayrollDetailCategory {
  SALARY
  ATTENDANCE_DEDUCTION
  TAX
  BPJS
  LOAN
  OTHER
}

/// Master komponen gaji — dinamis & configurable (tidak hardcode).
/// calc_method:
///   FIXED   → nilai dari employee_salary_components.value
///   PERCENT → persentase dari basis_component_id; rate default di formula_expression,
///             dapat di-override per karyawan via employee_salary_components.value
///   FORMULA → ekspresi matematika di formula_expression (mis. "GAJI_POKOK * 0.0424")
model salary_components {
  id                 BigInt               @id @default(autoincrement()) @db.UnsignedBigInt
  code               String               @unique @db.VarChar(40)
  name               String               @db.VarChar(150)
  type               PayrollComponentType @default(EARNING)
  calc_method        PayrollCalcMethod    @default(FIXED)
  formula_expression String?              @db.Text
  default_rate       Decimal?             @db.Decimal(15, 4)
  basis_component_id BigInt?              @db.UnsignedBigInt
  calc_order         Int                  @default(0)
  is_taxable         Boolean              @default(false)
  is_active          Boolean              @default(true)
  is_statutory       Boolean              @default(false)
  is_prorata         Boolean              @default(false)
  is_thr_basis       Boolean              @default(false)
  created_at         DateTime?            @db.Timestamp(0)
  updated_at         DateTime?            @db.Timestamp(0)

  basis_component     salary_components?           @relation("SalaryComponentBasis", fields: [basis_component_id], references: [id], onDelete: SetNull, onUpdate: Restrict, map: "salary_components_basis_id_foreign")
  derived_components  salary_components[]          @relation("SalaryComponentBasis")
  employee_components employee_salary_components[]
  jabatan_components  jabatan_salary_components[]
  deduction_rules     attendance_deduction_rules[]
  slip_details        payroll_slip_details[]

  @@index([type], map: "salary_components_type_index")
  @@index([calc_order], map: "salary_components_calc_order_index")
  @@index([is_active], map: "salary_components_is_active_index")
  @@index([basis_component_id], map: "salary_components_basis_id_index")
}

/// Komponen gaji per karyawan (effective-dated). value = nominal (FIXED) atau persentase (PERCENT).
model employee_salary_components {
  id             BigInt    @id @default(autoincrement()) @db.UnsignedBigInt
  employee_id    BigInt    @db.UnsignedBigInt
  component_id   BigInt    @db.UnsignedBigInt
  value          Decimal   @default(0.0000) @db.Decimal(15, 4)
  effective_date DateTime  @db.Date
  end_date       DateTime? @db.Date
  created_at     DateTime? @db.Timestamp(0)
  updated_at     DateTime? @db.Timestamp(0)

  karyawans         karyawans         @relation(fields: [employee_id], references: [id], onDelete: Cascade, onUpdate: Restrict, map: "esc_employee_id_foreign")
  salary_components salary_components @relation(fields: [component_id], references: [id], onDelete: Restrict, onUpdate: Restrict, map: "esc_component_id_foreign")

  @@index([employee_id], map: "esc_employee_id_index")
  @@index([component_id], map: "esc_component_id_index")
  @@index([effective_date, end_date], map: "esc_effective_index")
}

/// Komponen gaji per JABATAN (effective-dated). Dipakai bila karyawan tidak
/// memiliki override per individu (employee_salary_components menang).
model jabatan_salary_components {
  id             BigInt    @id @default(autoincrement()) @db.UnsignedBigInt
  jabatan        String    @db.VarChar(255)
  component_id   BigInt    @db.UnsignedBigInt
  value          Decimal   @default(0.0000) @db.Decimal(15, 4)
  effective_date DateTime  @db.Date
  end_date       DateTime? @db.Date
  created_at     DateTime? @db.Timestamp(0)
  updated_at     DateTime? @db.Timestamp(0)

  salary_components salary_components @relation(fields: [component_id], references: [id], onDelete: Restrict, onUpdate: Restrict, map: "jsc_component_id_foreign")

  @@index([jabatan], map: "jsc_jabatan_index")
  @@index([component_id], map: "jsc_component_id_index")
  @@index([effective_date, end_date], map: "jsc_effective_index")
}

/// Aturan potongan absensi (configurable). basis_component_id biasanya GAJI_POKOK.
model attendance_deduction_rules {
  id                      BigInt                    @id @default(autoincrement()) @db.UnsignedBigInt
  name                    String                    @db.VarChar(150)
  trigger_type            AttendanceTriggerType
  calc_method             AttendanceDeductionMethod
  basis_component_id      BigInt?                   @db.UnsignedBigInt
  value                   Decimal                   @default(0.0000) @db.Decimal(15, 4)
  working_days            Int                       @default(22)
  tolerance_minutes       Int?
  max_deduction_per_month Decimal?                  @db.Decimal(15, 2)
  is_active               Boolean                   @default(true)
  created_at              DateTime?                 @db.Timestamp(0)
  updated_at              DateTime?                 @db.Timestamp(0)

  basis_component salary_components?      @relation(fields: [basis_component_id], references: [id], onDelete: SetNull, onUpdate: Restrict, map: "adr_basis_component_id_foreign")
  late_tiers      attendance_late_tiers[]

  @@index([trigger_type], map: "adr_trigger_type_index")
  @@index([is_active], map: "adr_is_active_index")
  @@index([basis_component_id], map: "adr_basis_component_id_index")
}

/// Tier keterlambatan progresif untuk aturan potongan absensi (trigger_type = LATE).
model attendance_late_tiers {
  id                BigInt                @id @default(autoincrement()) @db.UnsignedBigInt
  rule_id           BigInt                @db.UnsignedBigInt
  late_from_minutes Int
  late_to_minutes   Int?
  deduction_type    LateTierDeductionType
  deduction_value   Decimal               @default(0.0000) @db.Decimal(15, 4)
  created_at        DateTime?             @db.Timestamp(0)
  updated_at        DateTime?             @db.Timestamp(0)

  rule attendance_deduction_rules @relation(fields: [rule_id], references: [id], onDelete: Cascade, onUpdate: Restrict, map: "alt_rule_id_foreign")

  @@index([rule_id], map: "alt_rule_id_index")
  @@index([late_from_minutes], map: "alt_late_from_index")
}

/// Periode payroll (per bulan). Satu periode unik per (bulan, tahun).
model payroll_periods {
  id           BigInt              @id @default(autoincrement()) @db.UnsignedBigInt
  period_month Int                 @db.UnsignedTinyInt
  period_year  Int                 @db.UnsignedSmallInt
  // Rentang tanggal aktual periode (untuk absensi, komponen efektif, prorata).
  // NULL = pakai 1 s.d. akhir bulan (period_month/period_year) sebagai default.
  period_start_date DateTime?      @db.Date
  period_end_date   DateTime?      @db.Date
  run_type     PayrollRunType      @default(REGULER)
  thr_min_masa_bulan Int            @default(12)
  bonus_multiplier   Decimal       @default(1.00) @db.Decimal(6, 2)
  run_label    String?             @db.VarChar(150)
  status       PayrollPeriodStatus @default(DRAFT)
  notes        String?             @db.Text
  created_by   BigInt?             @db.UnsignedBigInt
  approved_by  BigInt?             @db.UnsignedBigInt
  tanggal_bayar DateTime?          @db.Date
  paid_by      BigInt?             @db.UnsignedBigInt
  paid_at      DateTime?           @db.Timestamp(0)
  closed_at    DateTime?           @db.Timestamp(0)
  created_at   DateTime?           @db.Timestamp(0)
  updated_at   DateTime?           @db.Timestamp(0)

  payroll_slips payroll_slips[]
  payroll_adjustments payroll_adjustments[]
  employee_loan_payments employee_loan_payments[]
  payroll_run_logs payroll_run_logs[]

  @@unique([period_month, period_year, run_type], map: "payroll_periods_month_year_type_unique")
  @@index([status], map: "payroll_periods_status_index")
}

/// Header payroll per karyawan — SNAPSHOT (working_days & total dibekukan).
model payroll_slips {
  id                BigInt            @id @default(autoincrement()) @db.UnsignedBigInt
  payroll_period_id BigInt            @db.UnsignedBigInt
  employee_id       BigInt            @db.UnsignedBigInt
  slip_number       String?           @db.VarChar(40)
  working_days      Int               @default(0)
  total_earnings    Decimal           @default(0.00) @db.Decimal(18, 2)
  total_deductions  Decimal           @default(0.00) @db.Decimal(18, 2)
  net_salary        Decimal           @default(0.00) @db.Decimal(18, 2)
  status            PayrollSlipStatus @default(PENDING)
  tax_detail        Json?
  attendance_snapshot Json?
  employee_snapshot Json?
  bank_snapshot     Json?
  reviewed_by       BigInt?           @db.UnsignedBigInt
  reviewed_at       DateTime?         @db.Timestamp(0)
  created_at        DateTime?         @db.Timestamp(0)
  updated_at        DateTime?         @db.Timestamp(0)

  payroll_periods payroll_periods        @relation(fields: [payroll_period_id], references: [id], onDelete: Cascade, onUpdate: Restrict, map: "ps_payroll_period_id_foreign")
  karyawans       karyawans              @relation(fields: [employee_id], references: [id], onDelete: Restrict, onUpdate: Restrict, map: "ps_employee_id_foreign")
  details         payroll_slip_details[]
  loan_payments   employee_loan_payments[]
  payroll_run_logs payroll_run_logs[]

  @@unique([payroll_period_id, employee_id], map: "payroll_slips_period_employee_unique")
  @@index([employee_id], map: "payroll_slips_employee_id_index")
  @@index([status], map: "payroll_slips_status_index")
}

/// Log hasil kalkulasi payroll per periode/karyawan (error/warning/info), agar
/// hasil validasi tetap bisa dilihat setelah halaman di-refresh.
model payroll_run_logs {
  id                BigInt    @id @default(autoincrement()) @db.UnsignedBigInt
  payroll_period_id BigInt    @db.UnsignedBigInt
  payroll_slip_id   BigInt?   @db.UnsignedBigInt
  employee_id       BigInt?   @db.UnsignedBigInt
  level             String    @db.VarChar(20)
  message           String    @db.VarChar(255)
  context           Json?
  created_at        DateTime? @db.Timestamp(0)

  payroll_periods payroll_periods @relation(fields: [payroll_period_id], references: [id], onDelete: Cascade, onUpdate: Restrict, map: "prl_period_id_foreign")
  payroll_slips   payroll_slips?  @relation(fields: [payroll_slip_id], references: [id], onDelete: SetNull, onUpdate: Restrict, map: "prl_slip_id_foreign")
  karyawans       karyawans?      @relation(fields: [employee_id], references: [id], onDelete: SetNull, onUpdate: Restrict, map: "prl_employee_id_foreign")

  @@index([payroll_period_id], map: "payroll_run_logs_period_id_index")
  @@index([payroll_slip_id], map: "payroll_run_logs_slip_id_index")
  @@index([employee_id], map: "payroll_run_logs_employee_id_index")
  @@index([level], map: "payroll_run_logs_level_index")
}

/// Detail payroll per komponen — SNAPSHOT baris (kode/nama komponen & nilai dibekukan).
model payroll_slip_details {
  id              BigInt                @id @default(autoincrement()) @db.UnsignedBigInt
  payroll_slip_id BigInt                @db.UnsignedBigInt
  component_id    BigInt?               @db.UnsignedBigInt
  component_code  String                @db.VarChar(40)
  component_name  String                @db.VarChar(150)
  type            PayrollComponentType
  category        PayrollDetailCategory @default(OTHER)
  basis_value     Decimal               @default(0.00) @db.Decimal(18, 2)
  quantity        Decimal               @default(1.00) @db.Decimal(10, 2)
  amount          Decimal               @default(0.00) @db.Decimal(18, 2)
  notes           String?               @db.VarChar(255)
  sort_order      Int                   @default(0)
  created_at      DateTime?             @db.Timestamp(0)
  updated_at      DateTime?             @db.Timestamp(0)

  payroll_slips     payroll_slips      @relation(fields: [payroll_slip_id], references: [id], onDelete: Cascade, onUpdate: Restrict, map: "psd_payroll_slip_id_foreign")
  salary_components salary_components? @relation(fields: [component_id], references: [id], onDelete: SetNull, onUpdate: Restrict, map: "psd_component_id_foreign")

  @@index([payroll_slip_id], map: "payroll_slip_details_slip_id_index")
  @@index([component_id], map: "payroll_slip_details_component_id_index")
}

enum LoanStatus {
  ACTIVE
  COMPLETED
  CANCELLED
}

/// Pinjaman/cicilan karyawan. Potongan cicilan otomatis tiap payroll REGULER
/// sampai sisa pokok habis. Snapshot potongan dicatat di employee_loan_payments.
model employee_loans {
  id                 BigInt     @id @default(autoincrement()) @db.UnsignedBigInt
  employee_id        BigInt     @db.UnsignedBigInt
  loan_number        String?    @db.VarChar(40)
  title              String     @db.VarChar(150)
  principal_amount   Decimal    @default(0.00) @db.Decimal(18, 2)
  installment_amount Decimal    @default(0.00) @db.Decimal(18, 2)
  tenor_months       Int        @default(0)
  start_month        Int        @db.UnsignedTinyInt
  start_year         Int        @db.UnsignedSmallInt
  status             LoanStatus @default(ACTIVE)
  notes              String?    @db.Text
  created_at         DateTime?  @db.Timestamp(0)
  updated_at         DateTime?  @db.Timestamp(0)

  karyawans karyawans                @relation(fields: [employee_id], references: [id], onDelete: Cascade, onUpdate: Restrict, map: "loan_employee_id_foreign")
  payments  employee_loan_payments[]

  @@index([employee_id], map: "employee_loans_employee_id_index")
  @@index([status], map: "employee_loans_status_index")
}

/// Riwayat potongan cicilan per periode payroll (snapshot, idempotent per slip).
model employee_loan_payments {
  id              BigInt    @id @default(autoincrement()) @db.UnsignedBigInt
  loan_id         BigInt    @db.UnsignedBigInt
  payroll_slip_id BigInt?   @db.UnsignedBigInt
  payroll_period_id BigInt? @db.UnsignedBigInt
  period_month    Int       @db.UnsignedTinyInt
  period_year     Int       @db.UnsignedSmallInt
  amount          Decimal   @default(0.00) @db.Decimal(18, 2)
  created_at      DateTime? @db.Timestamp(0)
  updated_at      DateTime? @db.Timestamp(0)

  loan          employee_loans @relation(fields: [loan_id], references: [id], onDelete: Cascade, onUpdate: Restrict, map: "loanpay_loan_id_foreign")
  payroll_slips payroll_slips? @relation(fields: [payroll_slip_id], references: [id], onDelete: SetNull, onUpdate: Restrict, map: "loanpay_slip_id_foreign")
  payroll_periods payroll_periods? @relation(fields: [payroll_period_id], references: [id], onDelete: Cascade, onUpdate: Restrict, map: "loanpay_period_id_foreign")

  @@index([loan_id], map: "employee_loan_payments_loan_id_index")
  @@index([payroll_slip_id], map: "employee_loan_payments_slip_id_index")
  @@index([payroll_period_id], map: "employee_loan_payments_period_id_index")
  @@index([period_year, period_month], map: "employee_loan_payments_period_index")
}

/// Penyesuaian sekali jalan (one-time) per periode payroll & karyawan.
/// Disuntik sebagai komponen FIXED saat kalkulasi (mis. bonus proyek, denda).
model payroll_adjustments {
  id                BigInt               @id @default(autoincrement()) @db.UnsignedBigInt
  payroll_period_id BigInt               @db.UnsignedBigInt
  employee_id       BigInt               @db.UnsignedBigInt
  type              PayrollComponentType @default(EARNING)
  label             String               @db.VarChar(150)
  amount            Decimal              @default(0.00) @db.Decimal(18, 2)
  is_taxable        Boolean              @default(false)
  notes             String?              @db.VarChar(255)
  created_at        DateTime?            @db.Timestamp(0)
  updated_at        DateTime?            @db.Timestamp(0)

  payroll_periods payroll_periods @relation(fields: [payroll_period_id], references: [id], onDelete: Cascade, onUpdate: Restrict, map: "padj_period_id_foreign")
  karyawans       karyawans       @relation(fields: [employee_id], references: [id], onDelete: Cascade, onUpdate: Restrict, map: "padj_employee_id_foreign")

  @@index([payroll_period_id], map: "payroll_adjustments_period_id_index")
  @@index([employee_id], map: "payroll_adjustments_employee_id_index")
}

// ─── Compliance Pajak (PPh21) & BPJS ─────────────────────────────

/// Pengaturan BPJS per jenis (KES, JHT, JP, JKK, JKM) — configurable.
model bpjs_settings {
  id                   BigInt    @id @default(autoincrement()) @db.UnsignedBigInt
  kode                 String    @unique @db.VarChar(20)
  nama                 String    @db.VarChar(100)
  rate_karyawan        Decimal   @default(0.0000) @db.Decimal(7, 4)
  rate_perusahaan      Decimal   @default(0.0000) @db.Decimal(7, 4)
  batas_atas_upah      Decimal?  @db.Decimal(15, 2)
  basis_component_code String    @default("GAJI_POKOK") @db.VarChar(40)
  menambah_bruto_pajak Boolean   @default(false)
  pengurang_pajak      Boolean   @default(false)
  is_active            Boolean   @default(true)
  urutan               Int       @default(0)
  keterangan           String?   @db.VarChar(255)
  created_at           DateTime? @db.Timestamp(0)
  updated_at           DateTime? @db.Timestamp(0)
}

/// PTKP + kategori TER (configurable).
model ptkp_settings {
  id              BigInt    @id @default(autoincrement()) @db.UnsignedBigInt
  kode            String    @unique @db.VarChar(10)
  nama            String    @db.VarChar(100)
  nominal_setahun Decimal   @db.Decimal(15, 2)
  kategori_ter    String    @default("A") @db.VarChar(1)
  is_active       Boolean   @default(true)
  urutan          Int       @default(0)
  created_at      DateTime? @db.Timestamp(0)
  updated_at      DateTime? @db.Timestamp(0)
}

/// Lapisan tarif progresif PPh21 (UU HPP).
model pph21_brackets {
  id           BigInt    @id @default(autoincrement()) @db.UnsignedBigInt
  urutan       Int       @default(0)
  batas_bawah  Decimal   @default(0.00) @db.Decimal(18, 2)
  batas_atas   Decimal?  @db.Decimal(18, 2)
  tarif_persen Decimal   @default(0.00) @db.Decimal(5, 2)
  created_at   DateTime? @db.Timestamp(0)
  updated_at   DateTime? @db.Timestamp(0)
}

/// Tarif Efektif Rata-rata (TER) PPh21 bulanan — PP 58/2023.
model pph21_ter_rates {
  id           BigInt    @id @default(autoincrement()) @db.UnsignedBigInt
  kategori     String    @db.VarChar(1)
  bruto_min    Decimal   @default(0.00) @db.Decimal(18, 2)
  bruto_max    Decimal?  @db.Decimal(18, 2)
  tarif_persen Decimal   @default(0.000) @db.Decimal(6, 3)
  urutan       Int       @default(0)
  created_at   DateTime? @db.Timestamp(0)
  updated_at   DateTime? @db.Timestamp(0)

  @@unique([kategori, bruto_min], map: "pph21_ter_rates_kategori_min_unique")
  @@index([kategori, bruto_min], map: "pph21_ter_rates_kategori_index")
}

/// Konfigurasi pajak global (single row).
model payroll_tax_configs {
  id                       BigInt    @id @default(autoincrement()) @db.UnsignedBigInt
  biaya_jabatan_persen     Decimal   @default(5.00) @db.Decimal(5, 2)
  biaya_jabatan_maks_bulan Decimal   @default(500000.00) @db.Decimal(15, 2)
  metode_pph21             String    @default("PROGRESIF") @db.VarChar(20)
  npwp_surcharge_persen    Decimal   @default(20.00) @db.Decimal(5, 2)
  pembulatan_pph           Int       @default(0)
  pembulatan_gaji          Int       @default(0)
  bpjs_enabled             Boolean   @default(true)
  pph21_enabled            Boolean   @default(true)
  created_at               DateTime? @db.Timestamp(0)
  updated_at               DateTime? @db.Timestamp(0)
}
