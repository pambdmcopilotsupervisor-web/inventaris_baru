  @@index([karyawan_id], map: "overtime_requests_karyawan_id_index")
  @@index([status], map: "overtime_requests_status_index")
  @@index([tanggal_lembur], map: "overtime_requests_tanggal_index")
}

model overtime_approvals {
  id                  BigInt            @id @default(autoincrement()) @db.UnsignedBigInt
  overtime_request_id BigInt            @db.UnsignedBigInt
  approver_id         BigInt?           @db.UnsignedBigInt
  approver_user_id    BigInt?           @db.UnsignedBigInt
  approver_role       String            @db.VarChar(50)
  approval_level      Int
  status              String            @default("pending") @db.VarChar(20)
  note                String?           @db.Text
  approved_at         DateTime?         @db.Timestamp(0)
  created_at          DateTime?         @db.Timestamp(0)
  updated_at          DateTime?         @db.Timestamp(0)
